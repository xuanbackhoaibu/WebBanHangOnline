@model WebBanHangOnline.Models.Product

@{
ViewData["Title"] = Model.Name;

var averageRating = Model.Reviews != null && Model.Reviews.Any()
? Model.Reviews.Average(r => r.Rating)
: 0;

var reviewCount = Model.Reviews?.Count ?? 0;

var isFlashSale = Model.FlashSalePrice.HasValue
&& Model.FlashSaleEnd.HasValue
&& Model.FlashSaleEnd > DateTime.Now;

var mainImage = Model.Images?.FirstOrDefault()?.ImageUrl ?? Model.Thumbnail;
}

<style>
    body { background:#f5f5f5; }

    .product-container {
        background:#fff;
        padding:25px;
        border-radius:12px;
        box-shadow:0 4px 20px rgba(0,0,0,.05);
    }

    #mainImage { transition: opacity .3s ease; }

    .thumbnail-img {
        width:70px;
        height:70px;
        object-fit:cover;
        cursor:pointer;
        border:1px solid #ddd;
        border-radius:6px;
        transition:.2s;
    }
    .thumbnail-img:hover { transform:scale(1.05); }
    .thumbnail-img.active-thumb {
        border:2px solid #ee4d2d;
        transform:scale(1.08);
    }

    .variant-btn {
        border:1px solid #ddd;
        padding:6px 14px;
        margin:4px;
        border-radius:6px;
        cursor:pointer;
        background:#fff;
        transition:.2s;
    }
    .variant-btn:hover { border-color:#ee4d2d; }
    .variant-btn.active {
        border-color:#ee4d2d;
        color:#ee4d2d;
        font-weight:600;
    }

    .flash-sale {
        background:#ff424f;
        color:white;
        padding:6px 12px;
        border-radius:6px;
        font-size:14px;
    }

    .price-old { text-decoration:line-through; color:gray; }

    .variant-error {
        background:#fff0f0;
        color:#ff424f;
        padding:10px 14px;
        border-radius:6px;
        border:1px solid #ffccd2;
        margin-bottom:12px;
        display:none;
        animation:fadeSlide .3s ease;
    }

    @@keyframes fadeSlide {
        from {opacity:0; transform:translateY(-5px);}
        to {opacity:1; transform:translateY(0);}
    }

    .shake { animation:shake .3s; }
    @@keyframes shake {
        0%{transform:translateX(0);}
        25%{transform:translateX(-6px);}
        50%{transform:translateX(6px);}
        75%{transform:translateX(-6px);}
        100%{transform:translateX(0);}
    }

    .btn-disabled {
        opacity:.6 !important;
        pointer-events:none;
    }

    .highlight-missing {
        border:2px solid #ff424f !important;
    }

    .product-tabs{
        margin-top:40px;
    }

    .product-tabs .nav-link{
        color:#333;
        font-weight:500;
    }

    .product-tabs .nav-link.active{
        color:#ee4d2d;
        border-color:#ee4d2d #ee4d2d #fff;
    }

    .product-description{
        line-height:1.8;
        font-size:15px;
    }

    .review-item{
        border-bottom:1px solid #eee;
        padding:12px 0;
    }

    .review-star{
        color:#ffc107;
    }
</style>

<div class="container mt-4">
    <div class="product-container">
        <div class="row">

            <div class="col-md-5">

                <img id="mainImage"
                     src="@mainImage"
                     class="img-fluid border rounded mb-3" />

                <div class="d-flex gap-2 flex-wrap">
                    @if (Model.Images != null && Model.Images.Any())
                    {
                        foreach (var img in Model.Images)
                        {
                            <img src="@img.ImageUrl"
                                 class="thumbnail-img @(img.ImageUrl == mainImage ? "active-thumb" : "")" />
                        }
                    }
                </div>

            </div>

            <div class="col-md-7">

                <h3>@Model.Name</h3>

                <div class="mb-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= averageRating ? "bi-star-fill text-warning" : "bi-star text-warning")"></i>
                    }
                    <span class="ms-2">
                        @averageRating.ToString("0.0") (@reviewCount đánh giá)
                    </span>
                </div>

                @if (isFlashSale)
                {
                    <div class="flash-sale mb-2">
                        🔥 Flash Sale kết thúc sau:
                        <span id="countdown"></span>
                    </div>
                }

                <div class="mb-3">
                    @if (isFlashSale)
                    {
                        <span class="price-old">@Model.Price.ToString("N0") ₫</span>
                        <h3 class="text-danger">@Model.FlashSalePrice?.ToString("N0") ₫</h3>
                    }
                    else
                    {
                        <h3 class="text-danger">@Model.Price.ToString("N0") ₫</h3>
                    }
                </div>

                <form id="cartForm" asp-controller="Cart" asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="variantId" id="variantId" />

                    <div class="mb-2">
                        <label class="fw-bold">Size</label><br />
                        @if (Model.Variants != null)
                        {
                            foreach (var s in Model.Variants.Select(v => v.Size).Distinct())
                            {
                                <button type="button"
                                        class="variant-btn size-btn"
                                        data-size="@s">@s</button>
                            }
                        }
                    </div>

                    <div class="mb-2">
                        <label class="fw-bold">Màu</label><br />
                        <div id="colorContainer"></div>
                    </div>

                    <div class="mb-2 text-muted">
                        Tồn kho:
                        <span id="stockText">Vui lòng chọn phân loại</span>
                    </div>

                    <div id="variantError" class="variant-error">
                        ⚠ Vui lòng chọn đầy đủ Size và Màu trước khi tiếp tục.
                    </div>

                    <div class="mb-3">
                        <input type="number"
                               name="quantity"
                               id="quantityInput"
                               value="1"
                               min="1"
                               class="form-control"
                               style="width:120px"/>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                id="addToCartBtn"
                                class="btn btn-success btn-disabled">
                            🛒 Thêm vào giỏ
                        </button>

                        <button type="button"
                                id="buyNowBtn"
                                class="btn btn-danger btn-disabled"
                                onclick="buyNow()">
                            Mua ngay
                        </button>
                    </div>
                    
                    

                </form>

                
            </div>
        </div>
    </div>
    
    <div class="container product-tabs">

    <div class="product-container">

        <ul class="nav nav-tabs" id="productTab" role="tablist">

            <li class="nav-item">
                <button class="nav-link active"
                        data-bs-toggle="tab"
                        data-bs-target="#desc">
                    Mô tả sản phẩm
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                        data-bs-toggle="tab"
                        data-bs-target="#info">
                    Thông tin sản phẩm
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link"
                        data-bs-toggle="tab"
                        data-bs-target="#review">
                    Đánh giá (@reviewCount)
                </button>
            </li>

        </ul>

        <div class="tab-content pt-3">

            <!-- DESCRIPTION -->
            <div class="tab-pane fade show active" id="desc">

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="product-description">
                        @Html.Raw(Model.Description)
                    </div>
                }
                else
                {
                    <p class="text-muted">
                        Sản phẩm chưa có mô tả.
                    </p>
                }

            </div>


            <!-- PRODUCT INFO -->
            <div class="tab-pane fade" id="info">

                <table class="table">

                    <tr>
                        <th width="200">Tên sản phẩm</th>
                        <td>@Model.Name</td>
                    </tr>

                    <tr>
                        <th>Danh mục</th>
                        <td>@Model.Category?.Name</td>
                    </tr>

                    <tr>
                        <th>Giá</th>
                        <td>@Model.Price.ToString("N0") ₫</td>
                    </tr>

                    @if(Model.IsFlashSaleActive)
                    {
                        <tr>
                            <th>Flash Sale</th>
                            <td class="text-danger">
                                @Model.FlashSalePrice?.ToString("N0") ₫
                            </td>
                        </tr>
                    }

                </table>

            </div>


            <!-- REVIEWS -->
            <div class="tab-pane fade" id="review">

                @if(Model.Reviews != null && Model.Reviews.Any())
                {
                    foreach(var r in Model.Reviews)
                    {
                        <div class="review-item">

                            <div class="fw-bold">
                                @r.UserName
                            </div>

                            <div class="review-star">
                                @for(int i=1;i<=5;i++)
                                {
                                    if(i<=r.Rating)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star"></i>
                                    }
                                }
                            </div>

                            <div class="mt-1">
                                @r.Comment
                            </div>

                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">
                        Chưa có đánh giá nào cho sản phẩm này.
                    </p>
                }

            </div>

        </div>

    </div>

</div>
</div>

@section Scripts{
<script>

    const variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    (Model.Variants ?? new List<WebBanHangOnline.Models.ProductVariant>())
    .Select(v => new { v.Id, v.Size, v.Color, v.Stock })
    ));

    let selectedSize = null;
    let selectedColor = null;
    let selectedStock = 0;

    // IMAGE
    document.querySelectorAll(".thumbnail-img").forEach(img=>{
        img.addEventListener("mouseenter",function(){
            const mainImg = document.getElementById("mainImage");
            mainImg.style.opacity=0;
            setTimeout(()=>{
                mainImg.src=this.src;
                mainImg.style.opacity=1;
            },150);
            document.querySelectorAll(".thumbnail-img")
                .forEach(t=>t.classList.remove("active-thumb"));
            this.classList.add("active-thumb");
        });
    });

    // SIZE
    document.querySelectorAll(".size-btn").forEach(btn=>{
        btn.addEventListener("click",function(){
            document.querySelectorAll(".size-btn")
                .forEach(b=>b.classList.remove("active"));
            this.classList.add("active");
            selectedSize=this.dataset.size;
            selectedColor=null;
            document.getElementById("variantId").value="";
            renderColors();
            updateButtons();
        });
    });

    function renderColors(){
        const container=document.getElementById("colorContainer");
        container.innerHTML="";
        const colors=[...new Set(
            variants.filter(v=>v.Size===selectedSize).map(v=>v.Color)
        )];
        colors.forEach(c=>{
            const btn=document.createElement("button");
            btn.type="button";
            btn.className="variant-btn";
            btn.innerText=c;
            btn.onclick=function(){
                document.querySelectorAll("#colorContainer .variant-btn")
                    .forEach(b=>b.classList.remove("active"));
                this.classList.add("active");
                selectedColor=c;
                setVariant();
            };
            container.appendChild(btn);
        });
    }

    function setVariant(){
        const variant=variants.find(v=>
            v.Size===selectedSize && v.Color===selectedColor
        );
        if(!variant) return;
        selectedStock=variant.Stock;
        document.getElementById("variantId").value=variant.Id;
        document.getElementById("stockText").innerText=
            variant.Stock+" sản phẩm có sẵn";
        updateButtons();
    }

    function updateButtons(){
        const addBtn=document.getElementById("addToCartBtn");
        const buyBtn=document.getElementById("buyNowBtn");
        if(selectedSize && selectedColor){
            addBtn.classList.remove("btn-disabled");
            buyBtn.classList.remove("btn-disabled");
        }else{
            addBtn.classList.add("btn-disabled");
            buyBtn.classList.add("btn-disabled");
        }
}

    document.getElementById("cartForm").addEventListener("submit",function(e){
        const variantId=document.getElementById("variantId").value;
        const quantity=parseInt(document.getElementById("quantityInput").value);

        if(!variantId){
            e.preventDefault();
            showError();
            return;
        }

        if(quantity>selectedStock){
            e.preventDefault();
            alert("Số lượng vượt quá tồn kho!");
            return;
        }
});

    function buyNow(){

        const variantId = document.getElementById("variantId").value;
        const quantity = parseInt(document.getElementById("quantityInput").value);

        if(!variantId){
            showError();
            return;
        }

        let form = document.createElement("form");
        form.method = "post";
        form.action = '/Order/BuyNow';

        let token = document.querySelector('#cartForm input[name="__RequestVerificationToken"]');
        if (token) {
            let hiddenToken = document.createElement("input");
            hiddenToken.type = "hidden";
            hiddenToken.name = "__RequestVerificationToken";
            hiddenToken.value = token.value;
            form.appendChild(hiddenToken);
        }

        let inputVariant = document.createElement("input");
        inputVariant.type = "hidden";
        inputVariant.name = "variantId";
        inputVariant.value = variantId;
        form.appendChild(inputVariant);

        let inputQuantity = document.createElement("input");
        inputQuantity.type = "hidden";
        inputQuantity.name = "quantity";
        inputQuantity.value = quantity;
        form.appendChild(inputQuantity);

        document.body.appendChild(form);
        form.submit();
    }

    function showError(){
        const errorBox=document.getElementById("variantError");
        errorBox.style.display="block";
        errorBox.scrollIntoView({behavior:"smooth",block:"center"});
        document.getElementById("addToCartBtn").classList.add("shake");
        document.getElementById("buyNowBtn").classList.add("shake");
        setTimeout(()=>{
            document.getElementById("addToCartBtn").classList.remove("shake");
            document.getElementById("buyNowBtn").classList.remove("shake");
        },300);
    }

    // FLASH SALE
    var flashSaleEnd='@(Model.FlashSaleEnd?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "")';
    if(flashSaleEnd){
        var countDownDate=new Date(flashSaleEnd).getTime();
        var timer=setInterval(function(){
            var now=new Date().getTime();
            var distance=countDownDate-now;
            if(distance<=0){
                document.getElementById("countdown").innerHTML="Đã kết thúc";
                clearInterval(timer);
                return;
            }
            var h=Math.floor((distance%(1000*60*60*24))/(1000*60*60));
            var m=Math.floor((distance%(1000*60*60))/(1000*60));
            var s=Math.floor((distance%(1000*60))/1000);
            document.getElementById("countdown").innerHTML=
                h+"h "+m+"m "+s+"s";
        },1000);
    }

</script>
}