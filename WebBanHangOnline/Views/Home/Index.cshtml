@model List<WebBanHangOnline.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="home-page">

<!-- ================= HERO ================= -->
<section class="hero container">
    <div class="hero-content">
        <small class="hero-kicker">XUANBAC</small>
        <h1>Autumn<br />& Winter 2026</h1>

        <div class="hero-actions">
            <a asp-controller="Product"
               asp-action="Index"
               class="btn btn-primary btn-lg rounded-pill px-4 hero-btn">
                Mua sắm ngay
            </a>
            <a href="#women"
               class="btn btn-outline-danger btn-lg rounded-pill px-4 hero-btn">
                Khám phá thời trang nữ
            </a>
        </div>
    </div>
    <img src="/images/l.jpg" class="hero-img" alt="Hero banner" loading="lazy" />
</section>

<!-- ================= WOMEN ================= -->
<section id="women" class="section container">
    <div class="row align-items-center">
        <div class="col-lg-5">
            <img src="/images/women-banner.jpg" class="img-fluid">
        </div>
        <div class="col-lg-7">
            <h4 class="section-title"> THỜI TRANG NỮ </h4>
            <div class="row g-4">
                @foreach (var p in Model
                              .Where(x => x.Category != null 
                                          && x.Category.Name == "Đồ Nữ"
                                          && x.IsActive)
                              .Take(6))
                {
                    <div class="col-6 col-md-4">
                        <div class="product-card">
                            <span class="badge hot">HOT</span>
                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@p.ProductId"
                               asp-route-slug="@p.Slug">
                                <img src="@p.Thumbnail" />
                            </a>
                            <h6>@p.Name</h6>
                            <div class="price">@p.Price.ToString("N0") đ</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>


<!-- ================= SALE ================= -->
<section class="sale-box">
    <div class="sale-left">
        <img src="/images/d.jpg">
        <p>Mini backpack</p>
    </div>
    <div class="sale-center">
        <h3>Khuyến mãi giới hạn</h3>
        <h2>50% OFF</h2>
    </div>
    <div class="sale-right">
        <img src="/images/c.jpg">
    </div>
</section>

<!-- ================= MEN ================= -->
<section class="section container">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <h4 class="section-title">THỜI TRANG NAM </h4>
            <div class="row g-4">
                @foreach (var p in Model
                              .Where(x => x.Category != null 
                                          && x.Category.Name == "Đồ Nam"
                                          && x.IsActive)
                              .Take(6))
                {
                    <div class="col-6 col-md-4">
                        <div class="product-card">
                            <span class="badge sale">SALE</span>
                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@p.ProductId"
                               asp-route-slug="@p.Slug">
                                <img src="@p.Thumbnail" />
                            </a>
                            <h6>@p.Name</h6>
                            <div class="price">@p.Price.ToString("N0") đ</div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-5">
            <img src="/images/men-banner.jpg" class="img-fluid">
        </div>
    </div>
</section>

<!-- ================= BOYS ================= -->
<section class="section container">
    <div class="row align-items-center">
        <div class="col-lg-5">
            <img src="/images/boys-banner.jpg" class="img-fluid">
        </div>
        <div class="col-lg-7">
            <h4 class="section-title">THỜI TRANG BÉ TRAI</h4>
            <div class="row g-4">
                @foreach (var p in Model
                              .Where(x => x.Category != null 
                                          && x.Category.Name == "Bé Trai"
                                          && x.IsActive)
                              .Take(6))
                {
                    <div class="col-6 col-md-4">
                        <div class="product-card">
                            <span class="badge hot">HOT</span>
                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@p.ProductId"
                               asp-route-slug="@p.Slug">
                                <img src="@p.Thumbnail" />
                            </a>
                            <h6>@p.Name</h6>
                            <div class="price">@p.Price.ToString("N0") đ</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ================= GIRLS ================= -->
<section class="section container">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <h4 class="section-title">THỜI TRANG BÉ GÁI</h4>
            <div class="row g-4">
                @foreach (var p in Model
                              .Where(x => x.Category != null 
                                          && x.Category.Name == "Bé Gái"
                                          && x.IsActive)
                              .Take(6))
                {
                    <div class="col-6 col-md-4">
                        <div class="product-card">
                            <span class="badge sale">SALE</span>
                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@p.ProductId"
                               asp-route-slug="@p.Slug">
                                <img src="@p.Thumbnail" />
                            </a>
                            <h6>@p.Name</h6>
                            <div class="price">@p.Price.ToString("N0") đ</div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-5">
            <img src="/images/girls-banner.jpg" class="img-fluid">
        </div>
    </div>
</section>

<!-- ================= TABS ================= -->
<section class="tabs container">
    <div class="tab-head">
        <button class="tab-btn active" data-tab="popular">Phổ biến</button>
        <button class="tab-btn" data-tab="hot">Bán chạy</button>
        <button class="tab-btn" data-tab="sale">Khuyến mãi</button>
    </div>

    <!-- ===== PHỔ BIẾN ===== -->
    <div class="tab-body active" id="popular">
        <div class="row g-4">
            @foreach (var p in Model.Take(8))
            {
                <div class="col-6 col-md-3">
                    <div class="product-card">
                        <a asp-controller="Product"
                           asp-action="Details"
                           asp-route-id="@p.ProductId"
                           asp-route-slug="@p.Slug"
                           class="product-link">

                            <img src="@p.Thumbnail" />
                            <h6>@p.Name</h6>
                            <div class="price">@p.Price.ToString("N0") đ</div>

                        </a>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ===== BÁN CHẠY ===== -->
    <div class="tab-body" id="hot">
        <div class="row g-4">
            @foreach (var p in Model.Skip(4).Take(8))
            {
                <div class="col-6 col-md-3">
                    <div class="product-card">
                        <a asp-controller="Product"
                           asp-action="Details"
                           asp-route-id="@p.ProductId"
                           asp-route-slug="@p.Slug"
                           class="product-link">

                            <img src="@p.Thumbnail" />
                            <h6>@p.Name</h6>
                            <div class="price">@p.Price.ToString("N0") đ</div>

                        </a>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ===== KHUYẾN MÃI ===== -->
    <div class="tab-body" id="sale">
        <div class="row g-4">
            @foreach (var p in Model.Skip(8).Take(8))
            {
                <div class="col-6 col-md-3">
                    <div class="product-card">
                        <a asp-controller="Product"
                           asp-action="Details"
                           asp-route-id="@p.ProductId"
                           asp-route-slug="@p.Slug"
                           class="product-link">

                            <img src="@p.Thumbnail" />
                            <h6>@p.Name</h6>
                            <div class="price">@p.Price.ToString("N0") đ</div>

                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
<!-- ================= BLOG ================= -->
<section class="blog container">
    <h4 class="text-center mb-4">Xu hướng thời trang</h4>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="blog-card">
                <img src="/images/blog1.jpg" class="img-fluid blog-img" alt="Blog 1" loading="lazy">
                <div class="blog-body">
                    <h6>Beauty life style classic</h6>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="blog-card">
                <img src="/images/blog2.jpg" class="img-fluid blog-img" alt="Blog 2" loading="lazy">
                <div class="blog-body">
                    <h6>The need of life with vip style</h6>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="blog-card">
                <img src="/images/blog3.jpg" class="img-fluid blog-img" alt="Blog 3" loading="lazy">
                <div class="blog-body">
                    <h6>There is someone standing behind you</h6>
                </div>
            </div>
        </div>
    </div>
</section>

</div>

<style>
.home-page { background:#f7f7f7; }

/* HERO */
.hero {
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #ffffff 0%, rgba(255,107,107,.06) 55%, rgba(255,183,3,.06) 100%);
    padding: 56px 34px;
    margin-top: 0;
    border-radius: 22px;
    box-shadow: 0 14px 35px rgba(0,0,0,.06);
}

.hero-content { max-width:520px; }
.hero-img { width:520px; max-width:100%; margin-left:auto; border-radius: 18px; }


/* SECTION */
.section { margin:54px 0; }
.section-title { font-weight:800; margin-bottom:20px; letter-spacing: .2px; }

/* PRODUCT */
.product-card {
    position:relative;
    background:#fff;
    padding:12px;
    text-align:center;
    border:1px solid #eee;
    transition:.25s;
    border-radius: 16px;
    overflow: hidden;
}
.product-card:hover { 
    transform:translateY(-6px); 
    border-color:#ff6b6b; 
    box-shadow: 0 14px 28px rgba(255,107,107,.14);
}
.product-card img { 
    width:100%; 
    height:220px; 
    object-fit:cover; 
    border-radius: 12px;
}
.product-card h6 { font-size:14px; margin:10px 0 4px; }
.price { color:#ff6b6b; font-weight:700; }

/* BADGE */
.badge {
    position:absolute;
    top:10px;
    left:10px;
    padding:4px 8px;
    font-size:11px;
    color:#fff;
    border-radius: 999px;
    box-shadow: 0 6px 14px rgba(0,0,0,.12);
}
.badge.hot { background:#ff6b6b; }
.badge.sale { background:#ffb703; }

/* SALE BOX */
.sale-box {
    display:flex;
    align-items:center;
    justify-content:space-between;
    background:#fdecec;
    padding:30px;
    border-radius: 22px;
    box-shadow: 0 14px 35px rgba(0,0,0,.05);
}

/* TABS */
.tabs { margin:70px 0; }
.tab-head { text-align:center; margin-bottom:20px; }
.tab-head button {
    border:none;
    background:none;
    font-weight:600;
    margin:0 10px;
    cursor:pointer;
    padding: 10px 18px;
    border-radius: 999px;
}
.tab-head .active { 
    color:#fff; 
    background: #ff6b6b; 
    box-shadow: 0 10px 22px rgba(255,107,107,.2);
}

.tab-body { display:none; }
.tab-body.active { display:block; }

/* BLOG */
.blog-card{
    background:#fff;
    border: 1px solid #eee;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 10px 26px rgba(0,0,0,.04);
    transition: .25s;
}
.blog-card:hover{
    transform: translateY(-5px);
    box-shadow: 0 18px 40px rgba(0,0,0,.08);
    border-color: #ff6b6b;
}
.blog-img{
    width:100%;
    height: 200px;
    object-fit: cover;
}
.blog-body{
    padding: 14px 14px 16px;
}
.blog-body h6{
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
}

@@media (max-width: 991px) {
    .hero { flex-direction:column; text-align:center; }
    .hero-img { width:100%; margin:20px 0 0; }
}

.product-link {
    text-decoration: none;
    color: inherit;
    display: block;
}

.product-card h6 {
    font-size:14px;
    margin:10px 0 4px;

    display: -webkit-box;
    -webkit-line-clamp: 2;   /* chỉ hiển thị 2 dòng */
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.4;
    height: 2.8em; /* 2 dòng */
}

.hero-kicker{
    font-size:22px;
    letter-spacing:4px;
    font-weight:500;
    color:#333;
}

.hero-content h1{
    font-size:54px;
    font-weight:300;
    line-height:1.05;
    letter-spacing:1px;
    color:#222;
    margin: 0;
}

.hero-actions{
    display:flex;
    gap:12px;
    flex-wrap:wrap;
    margin-top: 22px;
}

.hero-btn{
    box-shadow: 0 8px 18px rgba(255,107,107,.18);
}

.hero-content{
    margin-left:0;
}
a {
    text-decoration: none; /* Xóa gạch chân */
    color: #000000;        /* Làm chữ thành màu đen thuần */
}

/* Hiệu ứng khi di chuột qua (tùy chọn) */
a:hover {
    color: #333333;        /* Chuyển sang màu xám đậm khi hover */
    text-decoration: none; /* Đảm bảo không hiện lại gạch chân */
}
/* 1. Xóa gạch chân và chỉnh màu đen cho tất cả liên kết trong footer */
footer a,
.footer-section a {
    text-decoration: none !important; /* Bỏ gạch chân */
    color: #333333 !important;        /* Màu đen xám (dễ nhìn hơn đen thuần) */
    transition: 0.3s;                 /* Hiệu ứng mượt khi di chuột */
}

/* 2. Hiệu ứng khi di chuột qua liên kết (tùy chọn) */
footer a:hover,
.footer-section a:hover {
    color: #000000;                   /* Đậm hơn khi hover */
    text-decoration: none;
}

/* 3. Xóa dấu chấm (bullet points) của danh sách */
footer ul,
.footer-section ul {
    list-style: none;                 /* Bỏ dấu chấm tròn */
    padding: 0;
    margin: 0;
}

/* 4. Chỉnh khoảng cách giữa các dòng cho thoáng */
footer li,
.footer-section li {
    margin-bottom: 8px;               /* Tạo khoảng cách giữa các mục */
}
</style>

@section Scripts {
<script>
document.querySelectorAll(".tab-btn").forEach(btn => {
    btn.addEventListener("click", () => {
        document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
        document.querySelectorAll(".tab-body").forEach(b => b.classList.remove("active"));

        btn.classList.add("active");
        document.getElementById(btn.dataset.tab).classList.add("active");
    });
});
</script>
}
