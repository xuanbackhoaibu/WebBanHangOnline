<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebBanHangOnline</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebBanHangOnline.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
</head>
<body class="coutura-body">

    <!-- ================= TOP BAR ================= -->
    <div class="coutura-topbar">
        <div class="container d-flex justify-content-between align-items-center small">

            <div class="d-flex gap-3">
                <span>Giao hàng toàn quốc</span>
            </div>

            <div class="d-flex align-items-center gap-4">

                <a asp-controller="Notification"
                   asp-action="Index"
                   class="text-decoration-none">
                    <i class="bi bi-bell"></i> Thông báo
                </a>

                <a asp-controller="Support"
                   asp-action="Index"
                   class="text-decoration-none">
                    <i class="bi bi-question-circle"></i> Hỗ trợ
                </a>
                <!-- Ngôn ngữ -->
                <div class="dropdown">
                    <a class="dropdown-toggle text-decoration-none"
                       href="javascript:void(0)"
                       data-bs-toggle="dropdown">
                        <i class="bi bi-globe"></i> Tiếng Việt
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="?lang=vi">🇻🇳 Tiếng Việt</a></li>
                        <li><a class="dropdown-item" href="?lang=en">🇬🇧 English</a></li>
                    </ul>
                </div>

                <!-- LOGIN / USER -->
                <ul class="nav align-items-center mb-0">
                    <partial name="_LoginPartial" />
                </ul>

            </div>

        </div>
    </div>

    <!-- ================= HEADER ================= -->
    <header class="coutura-header">
        <div class="container d-flex align-items-center justify-content-between gap-4">

            <!-- LOGO -->
            <a asp-controller="Home"
               asp-action="Index"
               class="coutura-logo">
                xuanbac<span>.</span>
            </a>

            <!-- SEARCH -->
            <form asp-controller="Product"
                  asp-action="Index"
                  method="get"
                  class="coutura-search flex-grow-1">

                <input type="text"
                       name="keyword"
                       class="form-control"
                       placeholder="Tìm sản phẩm..." />

                <button type="submit" class="btn btn-search">
                    <i class="bi bi-search"></i>
                </button>
            </form>

            <!-- ICONS -->
            <div class="header-icons d-flex align-items-center gap-3">

                <a href="#" class="icon-btn">
                    <i class="bi bi-search"></i>
                </a>

                <a href="#" class="icon-btn">
                    <i class="bi bi-heart"></i>
                </a>

                <!-- CART -->
                <a asp-controller="Cart"
                   asp-action="Index"
                   class="icon-btn position-relative">
                    <i class="bi bi-cart3"></i>
                    <span class="cart-badge">3</span>
                </a>
            </div>
        </div>
    </header>

    <!-- ================= MENU ================= -->
    <nav class="coutura-menu">
        <div class="container">
            <ul class="nav py-2 align-items-center">

                <li class="nav-item">
                    <a class="nav-link"
                       asp-area=""
                       asp-controller="Home"
                       asp-action="Index">
                        Trang chủ
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link"
                       asp-area=""
                       asp-controller="Product"
                       asp-action="Index">
                        Sản phẩm
                    </a>
                </li>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area=""
                           asp-controller="Order"
                           asp-action="MyOrders">
                            Đơn hàng của tôi
                        </a>
                    </li>
                }

                @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                {
                    <li class="nav-item dropdown ms-auto">
                        <a class="nav-link dropdown-toggle admin-link"
                           href="javascript:void(0)"
                           data-bs-toggle="dropdown">
                            Admin
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item"
                                   asp-area="Admin"
                                   asp-controller="Dashboard"
                                   asp-action="Index">
                                    Dashboard
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-area="Admin"
                                   asp-controller="Product"
                                   asp-action="Index">
                                    Quản lý sản phẩm
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-area="Admin"
                                   asp-controller="Order"
                                   asp-action="Index">
                                    Quản lý đơn hàng
                                </a>
                            </li>
                        </ul>
                    </li>
                }

            </ul>
        </div>
    </nav>

    <!-- ================= MAIN ================= -->
    <div class="container my-5">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- ================= FOOTER ================= -->
    <footer class="shop-footer">
        <div class="container footer-grid">

            <!-- LOGO + MÔ TẢ -->
            <div class="footer-col">
                <h4 class="logo">XUANBAC</h4>
                <p>Shop thời trang hiện đại dành cho nam, nữ và trẻ em. 
                    Luôn cập nhật xu hướng mới nhất.</p>

                <div class="social">
                    <a href="https://www.facebook.com/xuan.bac0706">Facebook</a>
                    <a href="https://www.instagram.com/bc_pupyw">Instagram</a>
                    <a href="#">TikTok</a>
                </div>
            </div>

            <!-- THÔNG TIN -->
            <div class="footer-col">
                <h6>Thông tin</h6>
                <ul>
                    <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li><a asp-controller="Home" asp-action="About">Giới thiệu</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">Chính sách</a></li>
                    <li><a asp-controller="Support" asp-action="Create">Liên hệ</a></li>
                </ul>
            </div>

            <!-- HỖ TRỢ -->
            <div class="footer-col">
                <h6>Hỗ trợ</h6>
                <ul>
                    <li><a href="#">Hỏi đáp</a></li>
                    <li><a href="#">Giao hàng</a></li>
                    <li><a href="#">Thanh toán</a></li>
                    <li><a href="#">Đổi trả</a></li>
                </ul>
            </div>

            <!-- NEWSLETTER -->
            <div class="footer-col">
                <h6>Đăng ký nhận tin</h6>
                <p>Nhận thông tin khuyến mãi mới nhất.</p>

                <div class="newsletter">
                    <input type="email" placeholder="Nhập email của bạn">
                    <button>Đăng ký</button>
                </div>

                <p class="contact">
                    Hotline: 0123 456 789<br>
                    Email: support@xuanbac.vn
                </p>
            </div>

        </div>

        <!-- COPYRIGHT -->
        <div class="footer-bottom">
            © 2026 XuanBac Fashion. All rights reserved.
        </div>
    </footer>

    @RenderSection("Scripts", required: false)

    <!-- ===== CHATBOT WIDGET ===== -->
    <input type="hidden" id="xb-chat-welcome" value="Xin chào @(User.Identity?.IsAuthenticated == true ? User.Identity?.Name : "bạn")! Bạn muốn mình tư vấn gì: size, phối đồ, hay gợi ý theo ngân sách?" />

    <div id="xb-chat-btn" title="Chat tư vấn">
        <i class="bi bi-chat-dots-fill"></i>
    </div>

    <div id="xb-chat-box" aria-live="polite">
        <div id="xb-chat-header">
            <div class="xb-chat-title">
                <div class="xb-chat-avatar">XB</div>
                <div class="xb-chat-title-text">
                    <b>Tư vấn nhanh</b>
                    <span id="xb-chat-status" class="xb-chat-status">Đang kết nối…</span>
                </div>
            </div>
            <div class="xb-chat-actions">
                <button type="button" id="xb-chat-clear" class="xb-icon-btn" title="Xoá lịch sử">
                    <i class="bi bi-trash3"></i>
                </button>
                <button type="button" id="xb-chat-close" class="xb-icon-btn" title="Đóng">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>

        <div id="xb-chat-body"></div>

        <div id="xb-chat-input">
            <input id="xb-chat-msg" placeholder="Nhập tin nhắn..." autocomplete="off" />
            <button id="xb-chat-send" type="button">Gửi</button>
        </div>
    </div>
    <!-- ===== END CHATBOT WIDGET ===== -->

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
</body>
</html>